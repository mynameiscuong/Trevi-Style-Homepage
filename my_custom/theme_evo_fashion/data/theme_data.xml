<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Website Menus -->
        <record id="menu_home" model="website.menu">
            <field name="name">Trang chủ</field>
            <field name="url">/</field>
            <field name="sequence" type="int">10</field>
        </record>

        <record id="menu_about" model="website.menu">
            <field name="name">Giới thiệu</field>
            <field name="url">/about-us</field>
            <field name="sequence" type="int">20</field>
        </record>

        <record id="menu_products" model="website.menu">
            <field name="name">Sản phẩm</field>
            <field name="url">/shop</field>
            <field name="sequence" type="int">30</field>
        </record>

        <record id="menu_new_arrivals" model="website.menu">
            <field name="name">Hàng mới</field>
            <field name="url">/shop?tag=new</field>
            <field name="sequence" type="int">40</field>
        </record>

        <record id="menu_shoes" model="website.menu">
            <field name="name">Giày dép</field>
            <field name="url">/shop?category=shoes</field>
            <field name="sequence" type="int">50</field>
        </record>

        <record id="menu_accessories" model="website.menu">
            <field name="name">Phụ kiện</field>
            <field name="url">/shop?category=accessories</field>
            <field name="sequence" type="int">60</field>
        </record>

        <record id="menu_blog" model="website.menu">
            <field name="name">Blog</field>
            <field name="url">/blog</field>
            <field name="sequence" type="int">70</field>
        </record>

        <record id="menu_contact" model="website.menu">
            <field name="name">Liên hệ</field>
            <field name="url">/contactus</field>
            <field name="sequence" type="int">80</field>
        </record>
    </data>
</odoo>
